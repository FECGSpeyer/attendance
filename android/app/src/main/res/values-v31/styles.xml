<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        On API 31+, AndroidX SplashScreen renders a built-in centered icon over
        a solid background — no bitmap stretching. windowSplashScreenAnimatedIcon
        wants the icon-only PNG (the framework adds its own circular mask and
        background). The legacy windowBackground is kept as a fallback for the
        instant before the splash API takes over.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
