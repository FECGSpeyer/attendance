# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

src/environments

*.log
log.txt
npm-debug.log*

package-lock.json

/.angular
/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

android/app/google-services.json
ios/App/App/GoogleService-Info.plist

resources/ios/**/*
resources/android/**/*

# Per-user Claude Code permissions / settings — not shared with the team.
.claude/settings.local.json

# OTA bundle signing — private key never leaves your machine / CI secret store
ota-private.pem